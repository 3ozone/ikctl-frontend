.idea/
*.swp
*.swo

# Docker (no incluir en el contexto de build)
Dockerfile*
docker-compose*.yml
.dockerignore

# TypeScript build info
tsconfig.tsbuildinfo

# Logs
*.log
npm-debug.log*

# Archivos temporales y del sistema operativo
*.tmp
*.bak
